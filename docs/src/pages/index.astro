---
import Layout from '../layouts/Layout.astro';
import IconGrid from '../components/IconGrid.astro';
import SearchBar from '../components/SearchBar.astro';
import Controls from '../components/Controls.astro';
import Preview from '../components/Preview.astro';
import { iconsData } from '../data/icons';

const totalIcons = iconsData.length;
---

<Layout title="drippia Icons - Beautiful Coffee & Beverage Icons">
  <div class="app-grid">
    <!-- Controls Column (1/3) -->
    <div class="controls-column">
      <!-- Search Section -->
      <section class="search-section">
        <div class="search-header">
          <h2 class="section-title">Icons</h2>
          <div class="stats">
            <span class="stat-number" id="totalIcons">{totalIcons}</span>
            <span class="stat-divider">/</span>
            <span class="stat-number" id="visibleIcons">{totalIcons}</span>
          </div>
        </div>
        <SearchBar />
      </section>

      <!-- Preview Section -->
      <section class="preview-section">
        <Preview />
      </section>

      <!-- Controls Section -->
      <section class="controls-section">
        <div class="controls-header">
          <h3 class="controls-title">Customize</h3>
        </div>
        <Controls />
        <div class="controls-footer">
          <p class="controls-description">Adjust size, stroke, and color to see how icons look in different contexts.</p>
        </div>
      </section>
    </div>

    <!-- Icons Section (2/3) -->
    <section class="icons-section">
      <IconGrid icons={iconsData} />
    </section>
  </div>
</Layout>

<script>
  import '../scripts/app.js';
</script>
